# ==========================================
# 🤖 核心 AI 引擎切换开关
# 可选值: 
#   - openai (代表使用云端 API，如 DeepSeek、通义千问等)
#   - local_gguf (代表使用本地断网版大模型)
#   - ollama (代表使用本地 Ollama 服务)
# ==========================================
AI_PROVIDER=openai

# ------------------------------------------
# ☁️ 选项 A: 云端 API 配置 (DeepSeek)
# ------------------------------------------
OPENAI_API_KEY=sk-xxxxxx      # 替换为你的 DeepSeek API 密钥
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ------------------------------------------
# 💻 选项 B: 本地纯离线配置 (GGUF 引擎)
# ------------------------------------------
# 将下载好的 gguf 文件放入 backend/models/ 目录下
GGUF_MODEL_NAME=DeepSeek-R1-Distill-Qwen-7B-Q4_K_M.gguf

# ------------------------------------------
# 🦙 选项 C: 本地 Ollama 配置
# ------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2:7b