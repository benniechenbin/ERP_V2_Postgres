# ==========================================
# 🤖 核心 AI 引擎切换开关
# 可选值: 
#   - openai (代表使用云端 API，如 DeepSeek、通义千问等)
#   - local_gguf (代表使用本地断网版大模型)
#   - ollama (代表使用本地 Ollama 服务)
# ==========================================
AI_PROVIDER=

# ------------------------------------------
# ☁️ 选项 A: 云端 API 配置 (DeepSeek)
# ------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ------------------------------------------
# 💻 选项 B: 本地纯离线配置 (GGUF 引擎)
# ------------------------------------------
# 将下载好的 gguf 文件放入 backend/models/ 目录下
GGUF_MODEL_NAME=

# ------------------------------------------
# 🦙 选项 C: 本地 Ollama 配置
# ------------------------------------------
OLLAMA_BASE_URL=
OLLAMA_MODEL=

DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=