# ==========================================
# 1. Python 虚拟环境与缓存
# ==========================================
__pycache__/
*.py[cod]
.venv/
venv/
env/
.conda/
.jupyter/
.Python

# ==========================================
# 2. 本地机密与临时运行数据
# ==========================================
# 绝对不要把本地环境配置和密钥传上网！
.env
*.log
*.sqlite
# 拦截本地测试产生的零碎数据
backup/
data/
backend/data/
data/uploads/

# ==========================================
# 3. 🤖 AI 模型与超大文件 (核心拦截区)
# ==========================================
# 忽略所有的 gguf 和 bin 模型文件
*.gguf
*.bin
# 彻底忽略 models 目录下的所有实体文件
backend/models/*
# 🟢 保留 models 文件夹本身的空壳和说明文档
!backend/models/.gitkeep
!backend/models/README.md

# ==========================================
# 4. 前端构建与依赖 (为未来 Vue/React 预留)
# ==========================================
node_modules/
build/
dist/

# ==========================================
# 5. 操作系统与 IDE 缓存
# ==========================================
.DS_Store
__MACOSX/
Thumbs.db
.idea/
.vscode/

# ==========================================
# 6. 打包文件
# ==========================================
*.tar
*.zip
*.gz